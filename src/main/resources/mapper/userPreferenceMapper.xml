<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.dailypick.mapper.UserPreferenceMapper">
    <resultMap id="UserPreferenceMap" type="com.project.dailypick.dto.UserPreferenceDto">
        <result property="categoryId" column="category_id"/>
        <result property="userId" column="user_id"/>
    </resultMap>

    <select id="getUserPreference" parameterType="long" resultMap="UserPreferenceMap">
        SELECT 
            category_id
        FROM user_preference
        WHERE user_id = #{userId}
    </select>
</mapper>