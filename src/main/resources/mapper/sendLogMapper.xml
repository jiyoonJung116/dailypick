<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.dailypick.mapper.SendLogMapper">
    <resultMap id="SendLogMap" type="com.project.dailypick.dto.SendLogDto">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="phoneNumber" column="phone_number"/>
        <result property="email" column="email"/>
        <result property="alarmTime" column="alarm_time"/>
        <result property="isSuccess" column="is_success"/>
        <result property="deliveryDate" column="delivery_date"/>
    </resultMap>

    <select id="getSendLogList" resultMap="SendLogMap" parameterType="map">
        SELECT *
        FROM send_log sl
        LEFT JOIN user u
        ON sl.user_id = u.id
        <where>
            <if test="userName != null">
                AND u.user_name = #{userName}
            </if>
            <if test="phoneNumber != null">
                AND UPPER(sl.phone_number) LIKE CONCAT('%', UPPER(#{phoneNumber}), '%')
            </if>
            <if test="email != null">
                AND UPPER(sl.email) LIKE CONCAT('%', UPPER(#{email}), '%')
            </if>
            <if test="isSuccess != null and isSuccess != 'ALL'">
                AND sl.is_success = #{isSuccess}
            </if>
        </where>
        ORDER BY alarm_time DESC
        LIMIT #{size} OFFSET #{offset}
    </select>
</mapper>