<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.dailypick.mapper.SubscriptionMapper">
    <resultMap id="SubscriptionMap" type="com.project.dailypick.dto.SubscriptionDto">
        <result property="categoryId" column="category_id"/>
        <result property="userId" column="user_id"/>
    </resultMap>

    <select id="getUserSubscription" parameterType="string" resultMap="SubscriptionMap">
        SELECT 
            *
        FROM subscription
        WHERE user_id = #{userId}
    </select>
</mapper>